#!/usr/bin/env bash
#
# VMANGOS Manager - Main CLI Entry Point
#

set -euo pipefail

# ============================================================================
# GLOBALS
# ============================================================================

readonly VERSION="0.1.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

readonly LIB_DIR="$SCRIPT_DIR/../lib"

# Global options (exported for use by sourced libraries)
VERBOSE=0
OUTPUT_FORMAT="text"
CONFIG_FILE="${MANAGER_CONFIG:-/opt/mangos/manager/config/manager.conf}"

# ============================================================================
# USAGE
# ============================================================================

show_help() {
    cat << 'EOF'
VMANGOS Manager - Server Management Tool
Version: 0.1.0

USAGE:
    vmangos-manager [GLOBAL_OPTIONS] <COMMAND> [SUBCOMMAND_OPTIONS]

GLOBAL OPTIONS:
    -c, --config FILE      Configuration file path
    -v, --verbose          Enable verbose output
    -f, --format FORMAT    Output format: text | json
    -h, --help             Show this help message
    --version              Show version information

COMMANDS:
    server [start|stop|restart|status] [OPTIONS]
      start options: [--wait] [--timeout SECONDS]
      stop options: [--graceful|--force] [--timeout SECONDS]
      restart options: [--timeout SECONDS]
      status options: [--format text|json] [--watch] [--interval SECONDS]
    dashboard [--refresh SECONDS] [--theme dark|light] [--bootstrap]
    logs [status|rotate|test-config|recent] [OPTIONS]
      recent options: [--source all|auth|world] [--window 15m|1h|1d] [--severity all|debug|info|notice|warning|error|critical|alert] [--limit N] [--watch|--follow] [--interval SECONDS] [--format text|json]
    account [create|list|setgm|ban|unban|password] [OPTIONS]
    update [check|inspect|plan|apply] [OPTIONS]
    schedule [honor|restart|list|cancel|simulate] [OPTIONS]
    config [create|validate|show|detect] [OPTIONS]
    backup [now|list|verify|restore|clean|schedule] [OPTIONS]
      schedule options: [status] [--daily HH:MM | --weekly "Sun 04:00"] [--format text|json]
EOF
}

show_version() {
    echo "VMANGOS Manager version $VERSION"
}

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

parse_global_options() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -f|--format)
                if [[ -n "${2:-}" ]]; then
                    OUTPUT_FORMAT="$2"
                    shift 2
                else
                    echo "Error: --format requires an argument" >&2
                    exit 2
                fi
                ;;
            -c|--config)
                if [[ -n "${2:-}" ]]; then
                    CONFIG_FILE="$2"
                    shift 2
                else
                    echo "Error: --config requires an argument" >&2
                    exit 2
                fi
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --version)
                show_version
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Error: Unknown option: $1" >&2
                exit 2
                ;;
            *)
                break
                ;;
        esac
    done
}

# ============================================================================
# COMMAND HANDLERS
# ============================================================================

# shellcheck source=lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=lib/config.sh  
source "$LIB_DIR/config.sh"
# shellcheck source=lib/server.sh
source "$LIB_DIR/server.sh"
# shellcheck source=lib/account.sh
source "$LIB_DIR/account.sh"
# shellcheck source=lib/update.sh
source "$LIB_DIR/update.sh"
# shellcheck source=lib/schedule.sh
source "$LIB_DIR/schedule.sh"
# shellcheck source=lib/backup.sh
source "$LIB_DIR/backup.sh"
# shellcheck source=lib/logs.sh
source "$LIB_DIR/logs.sh"
# shellcheck source=lib/dashboard.sh
source "$LIB_DIR/dashboard.sh"

# Export globals for library use
export VERBOSE
export OUTPUT_FORMAT

cmd_server() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        start)
            local wait=false
            local timeout=60
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --wait) wait=true; shift ;;
                    --timeout)
                        if [[ -n "${2:-}" ]]; then
                            timeout="$2"
                            shift 2
                        else
                            echo "Error: --timeout requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_start "$wait" "$timeout"
            ;;
            
        stop)
            local graceful=true force=false
            local timeout=30
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --graceful) graceful=true; shift ;;
                    --force) force=true; shift ;;
                    --timeout)
                        if [[ -n "${2:-}" ]]; then
                            timeout="$2"
                            shift 2
                        else
                            echo "Error: --timeout requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_stop "$graceful" "$force" "$timeout"
            ;;
            
        restart)
            local timeout=60
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --timeout)
                        if [[ -n "${2:-}" ]]; then
                            timeout="$2"
                            shift 2
                        else
                            echo "Error: --timeout requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_restart "$timeout"
            ;;
            
        status)
            local fmt="$OUTPUT_FORMAT"
            local watch=false
            local interval=2
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format)
                        if [[ -n "${2:-}" ]]; then
                            fmt="$2"
                            shift 2
                        else
                            echo "Error: --format requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --watch)
                        watch=true
                        shift
                        ;;
                    --interval)
                        if [[ -n "${2:-}" ]]; then
                            interval="$2"
                            shift 2
                        else
                            echo "Error: --interval requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done

            if [[ "$watch" == "true" ]]; then
                if [[ "$fmt" == "json" ]]; then
                    echo "Error: watch mode only supports text output" >&2
                    exit 2
                fi
                server_status_watch "$interval"
            elif [[ "$fmt" == "json" ]]; then
                server_status_json
            else
                server_status_text
            fi
            ;;
            
        *)
            echo "Error: Unknown server subcommand: $subcmd" >&2
            echo "Valid subcommands: start, stop, restart, status" >&2
            exit 2
            ;;
    esac
}

cmd_logs() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        status)
            local fmt="$OUTPUT_FORMAT"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format)
                        if [[ -n "${2:-}" ]]; then
                            fmt="$2"
                            shift 2
                        else
                            echo "Error: --format requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: logs status does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done

            if [[ "$fmt" == "json" ]]; then
                logs_status_json
            else
                logs_status_text
            fi
            ;;

        recent)
            local fmt="$OUTPUT_FORMAT"
            local source="all"
            local window="15m"
            local severity="all"
            local limit=25
            local watch=false
            local interval=2
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format)
                        if [[ -n "${2:-}" ]]; then
                            fmt="$2"
                            shift 2
                        else
                            echo "Error: --format requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --source)
                        if [[ -n "${2:-}" ]]; then
                            source="$2"
                            shift 2
                        else
                            echo "Error: --source requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --window)
                        if [[ -n "${2:-}" ]]; then
                            window="$2"
                            shift 2
                        else
                            echo "Error: --window requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --severity)
                        if [[ -n "${2:-}" ]]; then
                            severity="$2"
                            shift 2
                        else
                            echo "Error: --severity requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --limit)
                        if [[ -n "${2:-}" ]]; then
                            limit="$2"
                            shift 2
                        else
                            echo "Error: --limit requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --watch|--follow)
                        watch=true
                        shift
                        ;;
                    --interval)
                        if [[ -n "${2:-}" ]]; then
                            interval="$2"
                            shift 2
                        else
                            echo "Error: --interval requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: logs recent does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done

            if [[ "$watch" == "true" ]]; then
                if [[ "$fmt" == "json" ]]; then
                    echo "Error: watch mode only supports text output" >&2
                    exit 2
                fi
                logs_recent_watch "$source" "$window" "$severity" "$limit" "$interval"
            elif [[ "$fmt" == "json" ]]; then
                logs_recent_json "$source" "$window" "$severity" "$limit"
            else
                logs_recent_text "$source" "$window" "$severity" "$limit"
            fi
            ;;

        rotate)
            local force=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --force)
                        force=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: logs rotate does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            logs_rotate "$force"
            ;;

        test-config)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: logs test-config does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            logs_test_config
            ;;

        *)
            echo "Error: Unknown logs subcommand: $subcmd" >&2
            echo "Valid subcommands: status, recent, rotate, test-config" >&2
            exit 2
            ;;
    esac
}

cmd_dashboard() {
    local refresh=2
    local theme="dark"
    local bootstrap=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --refresh|--interval)
                if [[ -n "${2:-}" ]]; then
                    refresh="$2"
                    shift 2
                else
                    echo "Error: $1 requires an argument" >&2
                    exit 2
                fi
                ;;
            --theme)
                if [[ -n "${2:-}" ]]; then
                    theme="$2"
                    shift 2
                else
                    echo "Error: --theme requires an argument" >&2
                    exit 2
                fi
                ;;
            --bootstrap)
                bootstrap=true
                shift
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Unknown option: $1" >&2
                exit 2
                ;;
            *)
                echo "Error: dashboard does not accept positional arguments" >&2
                exit 2
                ;;
        esac
    done

    dashboard_run "$SCRIPT_DIR/vmangos-manager" "$refresh" "$theme" "$bootstrap"
}

cmd_schedule() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        honor)
            local time_value=""
            local schedule_type=""
            local schedule_day=""
            local timezone=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --time)
                        time_value="${2:-}"
                        shift 2
                        ;;
                    --daily)
                        schedule_type="daily"
                        shift
                        ;;
                    --weekly)
                        schedule_type="weekly"
                        schedule_day="${2:-}"
                        shift 2
                        ;;
                    --timezone)
                        timezone="${2:-}"
                        shift 2
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: schedule honor does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done

            if [[ -z "$time_value" || -z "$schedule_type" ]]; then
                echo "Error: schedule honor requires --time and one of --daily or --weekly DAY" >&2
                exit 2
            fi

            if [[ "$schedule_type" == "weekly" ]]; then
                schedule_honor "$schedule_type" "$schedule_day $time_value" "$timezone"
            else
                schedule_honor "$schedule_type" "$time_value" "$timezone"
            fi
            ;;

        restart)
            local time_value=""
            local schedule_type=""
            local schedule_day=""
            local timezone=""
            local warnings=""
            local announce_message=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --time)
                        time_value="${2:-}"
                        shift 2
                        ;;
                    --daily)
                        schedule_type="daily"
                        shift
                        ;;
                    --weekly)
                        schedule_type="weekly"
                        schedule_day="${2:-}"
                        shift 2
                        ;;
                    --timezone)
                        timezone="${2:-}"
                        shift 2
                        ;;
                    --warnings)
                        warnings="${2:-}"
                        shift 2
                        ;;
                    --announce)
                        announce_message="${2:-}"
                        shift 2
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: schedule restart does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done

            if [[ -z "$time_value" || -z "$schedule_type" ]]; then
                echo "Error: schedule restart requires --time and one of --daily or --weekly DAY" >&2
                exit 2
            fi

            schedule_load_config >/dev/null 2>&1 || true
            [[ -n "$warnings" ]] || warnings="${SCHEDULE_RESTART_WARNINGS:-30,15,5,1}"

            if [[ "$schedule_type" == "weekly" ]]; then
                schedule_restart_create "$schedule_type" "$schedule_day $time_value" "$timezone" "$warnings" "$announce_message"
            else
                schedule_restart_create "$schedule_type" "$time_value" "$timezone" "$warnings" "$announce_message"
            fi
            ;;

        list)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: schedule list does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            schedule_list
            ;;

        cancel)
            local job_id="${1:-}"
            if [[ -z "$job_id" ]]; then
                echo "Error: schedule cancel requires a job id" >&2
                exit 2
            fi
            schedule_cancel "$job_id"
            ;;

        simulate)
            local job_id="${1:-}"
            if [[ -z "$job_id" ]]; then
                echo "Error: schedule simulate requires a job id" >&2
                exit 2
            fi
            schedule_simulate "$job_id"
            ;;

        run-honor)
            local job_id="${1:-}"
            if [[ -z "$job_id" ]]; then
                echo "Error: schedule run-honor requires a job id" >&2
                exit 2
            fi
            schedule_run_honor "$job_id"
            ;;

        run-restart)
            local job_id="${1:-}"
            if [[ -z "$job_id" ]]; then
                echo "Error: schedule run-restart requires a job id" >&2
                exit 2
            fi
            schedule_run_restart "$job_id"
            ;;

        run-warning)
            local job_id="${1:-}"
            local warning_minutes="${2:-}"
            if [[ -z "$job_id" || -z "$warning_minutes" ]]; then
                echo "Error: schedule run-warning requires a job id and warning minutes" >&2
                exit 2
            fi
            schedule_run_warning "$job_id" "$warning_minutes"
            ;;

        *)
            echo "Error: Unknown schedule subcommand: $subcmd" >&2
            echo "Valid subcommands: honor, restart, list, cancel, simulate" >&2
            exit 2
            ;;
    esac
}

cmd_config() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        create)
            local path=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --path) path="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            
            if [[ -n "$path" ]]; then
                config_create "$path"
            else
                config_create
            fi
            ;;
            
        validate)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_validate "$CONFIG_FILE" "$fmt"
            ;;
            
        show)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_show "$CONFIG_FILE" "$fmt"
            ;;

        detect)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: config detect does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            config_detect "$fmt"
            ;;
            
        *)
            echo "Error: Unknown config subcommand: $subcmd" >&2
            echo "Valid subcommands: create, validate, show, detect" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# ACCOUNT COMMAND HANDLER
# ============================================================================

cmd_account() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create)
            local username=""
            local password_mode="interactive"
            local password_arg=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --password-file)
                        password_mode="file"
                        password_arg="${2:-}"
                        shift 2
                        ;;
                    --password-env)
                        password_mode="env"
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account create accepts only a username as a positional argument" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            [[ "$password_mode" != "file" || -n "$password_arg" ]] || { echo "Error: --password-file requires a path" >&2; exit 2; }
            account_create "$username" "$password_mode" "$password_arg"
            ;;

        list)
            local online_only=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --online)
                        online_only=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: account list does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            account_list "$online_only"
            ;;

        setgm)
            local username=""
            local gm_level=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                        elif [[ -z "$gm_level" ]]; then
                            gm_level="$1"
                        else
                            echo "Error: account setgm requires exactly <username> <level>" >&2
                            exit 2
                        fi
                        shift
                        ;;
                esac
            done
            if [[ -z "$username" || -z "$gm_level" ]]; then
                echo "Error: account setgm requires <username> <level>" >&2
                exit 2
            fi
            account_setgm "$username" "$gm_level"
            ;;

        ban)
            local username=""
            local duration=""
            local reason=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --reason)
                        reason="${2:-}"
                        shift 2
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                        elif [[ -z "$duration" ]]; then
                            duration="$1"
                        else
                            echo "Error: account ban requires <username> <duration> --reason <reason>" >&2
                            exit 2
                        fi
                        shift
                        ;;
                esac
            done
            if [[ -z "$username" || -z "$duration" || -z "$reason" ]]; then
                echo "Error: account ban requires <username> <duration> --reason <reason>" >&2
                exit 2
            fi
            account_ban "$username" "$duration" "$reason"
            ;;

        unban)
            local username=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account unban accepts only a username" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            account_unban "$username"
            ;;

        password)
            local username=""
            local password_mode="interactive"
            local password_arg=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --password-file)
                        password_mode="file"
                        password_arg="${2:-}"
                        shift 2
                        ;;
                    --password-env)
                        password_mode="env"
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account password accepts only a username as a positional argument" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            [[ "$password_mode" != "file" || -n "$password_arg" ]] || { echo "Error: --password-file requires a path" >&2; exit 2; }
            account_password "$username" "$password_mode" "$password_arg"
            ;;

        *)
            echo "Error: Unknown account subcommand: $subcmd" >&2
            echo "Valid subcommands: create, list, setgm, ban, unban, password" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# UPDATE COMMAND HANDLER
# ============================================================================

cmd_update() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        check)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update check does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_check
            ;;

        inspect)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update inspect does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_inspect
            ;;

        plan)
            local include_db=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --include-db)
                        include_db=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update plan does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_plan "$include_db"
            ;;

        apply)
            local backup_first=false
            local include_db=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --backup-first)
                        backup_first=true
                        shift
                        ;;
                    --include-db)
                        include_db=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update apply does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_apply "$backup_first" "$include_db"
            ;;

        *)
            echo "Error: Unknown update subcommand: $subcmd" >&2
            echo "Valid subcommands: check, inspect, plan, apply" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# BACKUP COMMAND HANDLER
# ============================================================================

cmd_backup() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        now)
            local verify=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --verify) verify=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_now "$verify"
            ;;
            
        list)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_list "$fmt"
            ;;
            
        verify)
            local file=""
            local level=1
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --level) level="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) 
                        if [[ -z "$file" ]]; then
                            file="$1"
                            shift
                        else
                            break
                        fi
                        ;;
                esac
            done
            if [[ -z "$file" ]]; then
                echo "Error: backup file required" >&2
                exit 2
            fi
            backup_verify "$file" "$level"
            ;;
            
        restore)
            local file=""
            local dry_run=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run) dry_run=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *)
                        if [[ -z "$file" ]]; then
                            file="$1"
                            shift
                        else
                            break
                        fi
                        ;;
                esac
            done
            if [[ -z "$file" ]]; then
                echo "Error: backup file required" >&2
                exit 2
            fi
            backup_restore "$file" "$dry_run"
            ;;
            
        clean)
            local keep_last=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --keep-last) keep_last="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_clean "$keep_last"
            ;;
            
        schedule)
            local status=false
            local schedule_type=""
            local schedule_value=""
            local fmt="$OUTPUT_FORMAT"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    status|--status) status=true; shift ;;
                    --daily) schedule_type="daily"; schedule_value="$2"; shift 2 ;;
                    --weekly) schedule_type="weekly"; schedule_value="$2"; shift 2 ;;
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) echo "Error: backup schedule accepts only 'status' or --daily/--weekly options" >&2; exit 2 ;;
                esac
            done
            if [[ "$status" == true ]]; then
                if [[ -n "$schedule_type" ]]; then
                    echo "Error: backup schedule status cannot be combined with --daily or --weekly" >&2
                    exit 2
                fi
                backup_schedule_status "$fmt"
            elif [[ -z "$schedule_type" ]]; then
                echo "Error: --daily or --weekly required" >&2
                exit 2
            else
                backup_schedule "$schedule_type" "$schedule_value"
            fi
            ;;
            
        *)
            echo "Error: Unknown backup subcommand: $subcmd" >&2
            echo "Valid subcommands: now, list, verify, restore, clean, schedule" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    parse_global_options "$@"
    
    # Shift consumed global options - parse_global_options stops at first non-option
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) shift ;;
            -f|--format) shift 2 ;;
            -c|--config) shift 2 ;;
            --) shift; break ;;
            -*) shift ;;  # Unknown option, let command handle it
            *) break ;;
        esac
    done
    
    if [[ $# -eq 0 ]]; then
        echo "Error: No command specified" >&2
        show_help >&2
        exit 2
    fi
    
    local command_name="$1"
    shift
    
    case "$command_name" in
        server)
            cmd_server "$@"
            ;;
        dashboard)
            cmd_dashboard "$@"
            ;;
        logs)
            cmd_logs "$@"
            ;;
        account)
            cmd_account "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        schedule)
            cmd_schedule "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        backup)
            cmd_backup "$@"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo "Error: Unknown command: $command_name" >&2
            show_help >&2
            exit 2
            ;;
    esac
}

main "$@"
