#!/usr/bin/env bash
#
# VMANGOS Manager - Main CLI Entry Point
#

set -euo pipefail

# ============================================================================
# GLOBALS
# ============================================================================

readonly VERSION="0.1.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPT_DIR

readonly LIB_DIR="$SCRIPT_DIR/../lib"

# Global options (exported for use by sourced libraries)
VERBOSE=0
OUTPUT_FORMAT="text"
CONFIG_FILE="${MANAGER_CONFIG:-/opt/mangos/manager/config/manager.conf}"

# ============================================================================
# USAGE
# ============================================================================

show_help() {
    cat << 'EOF'
VMANGOS Manager - Server Management Tool
Version: 0.1.0

USAGE:
    vmangos-manager [GLOBAL_OPTIONS] <COMMAND> [SUBCOMMAND_OPTIONS]

GLOBAL OPTIONS:
    -c, --config FILE      Configuration file path
    -v, --verbose          Enable verbose output
    -f, --format FORMAT    Output format: text | json
    -h, --help             Show this help message
    --version              Show version information

COMMANDS:
    server [start|stop|restart|status] [OPTIONS]
      status options: [--format text|json] [--watch] [--interval SECONDS]
    account [create|list|setgm|ban|unban|password] [OPTIONS]
    update [check|plan|apply] [OPTIONS]
    config [create|validate|show|detect] [OPTIONS]
    backup [now|list|verify|restore|clean|schedule] [OPTIONS]
EOF
}

show_version() {
    echo "VMANGOS Manager version $VERSION"
}

# ============================================================================
# ARGUMENT PARSING
# ============================================================================

parse_global_options() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=1
                shift
                ;;
            -f|--format)
                if [[ -n "${2:-}" ]]; then
                    OUTPUT_FORMAT="$2"
                    shift 2
                else
                    echo "Error: --format requires an argument" >&2
                    exit 2
                fi
                ;;
            -c|--config)
                if [[ -n "${2:-}" ]]; then
                    CONFIG_FILE="$2"
                    shift 2
                else
                    echo "Error: --config requires an argument" >&2
                    exit 2
                fi
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            --version)
                show_version
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Error: Unknown option: $1" >&2
                exit 2
                ;;
            *)
                break
                ;;
        esac
    done
}

# ============================================================================
# COMMAND HANDLERS
# ============================================================================

# shellcheck source=lib/common.sh
source "$LIB_DIR/common.sh"
# shellcheck source=lib/config.sh  
source "$LIB_DIR/config.sh"
# shellcheck source=lib/server.sh
source "$LIB_DIR/server.sh"
# shellcheck source=lib/account.sh
source "$LIB_DIR/account.sh"
# shellcheck source=lib/update.sh
source "$LIB_DIR/update.sh"
# shellcheck source=lib/backup.sh
source "$LIB_DIR/backup.sh"

# Export globals for library use
export VERBOSE
export OUTPUT_FORMAT

cmd_server() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        start)
            local wait=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --wait) wait=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_start "$wait"
            ;;
            
        stop)
            local graceful=true force=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --graceful) graceful=true; shift ;;
                    --force) force=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            server_stop "$graceful" "$force"
            ;;
            
        restart)
            server_restart
            ;;
            
        status)
            local fmt="$OUTPUT_FORMAT"
            local watch=false
            local interval=2
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format)
                        if [[ -n "${2:-}" ]]; then
                            fmt="$2"
                            shift 2
                        else
                            echo "Error: --format requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --watch)
                        watch=true
                        shift
                        ;;
                    --interval)
                        if [[ -n "${2:-}" ]]; then
                            interval="$2"
                            shift 2
                        else
                            echo "Error: --interval requires an argument" >&2
                            exit 2
                        fi
                        ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done

            if [[ "$watch" == "true" ]]; then
                if [[ "$fmt" == "json" ]]; then
                    echo "Error: watch mode only supports text output" >&2
                    exit 2
                fi
                server_status_watch "$interval"
            elif [[ "$fmt" == "json" ]]; then
                server_status_json
            else
                server_status_text
            fi
            ;;
            
        *)
            echo "Error: Unknown server subcommand: $subcmd" >&2
            echo "Valid subcommands: start, stop, restart, status" >&2
            exit 2
            ;;
    esac
}

cmd_config() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        create)
            local path=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --path) path="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            
            if [[ -n "$path" ]]; then
                config_create "$path"
            else
                config_create
            fi
            ;;
            
        validate)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_validate "$CONFIG_FILE" "$fmt"
            ;;
            
        show)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            config_show "$CONFIG_FILE" "$fmt"
            ;;

        detect)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: config detect does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            config_detect "$fmt"
            ;;
            
        *)
            echo "Error: Unknown config subcommand: $subcmd" >&2
            echo "Valid subcommands: create, validate, show, detect" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# ACCOUNT COMMAND HANDLER
# ============================================================================

cmd_account() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        create)
            local username=""
            local password_mode="interactive"
            local password_arg=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --password-file)
                        password_mode="file"
                        password_arg="${2:-}"
                        shift 2
                        ;;
                    --password-env)
                        password_mode="env"
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account create accepts only a username as a positional argument" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            [[ "$password_mode" != "file" || -n "$password_arg" ]] || { echo "Error: --password-file requires a path" >&2; exit 2; }
            account_create "$username" "$password_mode" "$password_arg"
            ;;

        list)
            local online_only=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --online)
                        online_only=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: account list does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            account_list "$online_only"
            ;;

        setgm)
            local username=""
            local gm_level=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                        elif [[ -z "$gm_level" ]]; then
                            gm_level="$1"
                        else
                            echo "Error: account setgm requires exactly <username> <level>" >&2
                            exit 2
                        fi
                        shift
                        ;;
                esac
            done
            if [[ -z "$username" || -z "$gm_level" ]]; then
                echo "Error: account setgm requires <username> <level>" >&2
                exit 2
            fi
            account_setgm "$username" "$gm_level"
            ;;

        ban)
            local username=""
            local duration=""
            local reason=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --reason)
                        reason="${2:-}"
                        shift 2
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                        elif [[ -z "$duration" ]]; then
                            duration="$1"
                        else
                            echo "Error: account ban requires <username> <duration> --reason <reason>" >&2
                            exit 2
                        fi
                        shift
                        ;;
                esac
            done
            if [[ -z "$username" || -z "$duration" || -z "$reason" ]]; then
                echo "Error: account ban requires <username> <duration> --reason <reason>" >&2
                exit 2
            fi
            account_ban "$username" "$duration" "$reason"
            ;;

        unban)
            local username=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account unban accepts only a username" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            account_unban "$username"
            ;;

        password)
            local username=""
            local password_mode="interactive"
            local password_arg=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --password-file)
                        password_mode="file"
                        password_arg="${2:-}"
                        shift 2
                        ;;
                    --password-env)
                        password_mode="env"
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        if [[ -z "$username" ]]; then
                            username="$1"
                            shift
                        else
                            echo "Error: account password accepts only a username as a positional argument" >&2
                            exit 2
                        fi
                        ;;
                esac
            done
            if [[ -z "$username" ]]; then
                echo "Error: username required" >&2
                exit 2
            fi
            [[ "$password_mode" != "file" || -n "$password_arg" ]] || { echo "Error: --password-file requires a path" >&2; exit 2; }
            account_password "$username" "$password_mode" "$password_arg"
            ;;

        *)
            echo "Error: Unknown account subcommand: $subcmd" >&2
            echo "Valid subcommands: create, list, setgm, ban, unban, password" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# UPDATE COMMAND HANDLER
# ============================================================================

cmd_update() {
    local subcmd="${1:-}"
    shift || true

    case "$subcmd" in
        check)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update check does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_check
            ;;

        plan)
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update plan does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_plan
            ;;

        apply)
            local backup_first=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --backup-first)
                        backup_first=true
                        shift
                        ;;
                    --)
                        shift
                        break
                        ;;
                    -*)
                        echo "Unknown option: $1" >&2
                        exit 2
                        ;;
                    *)
                        echo "Error: update apply does not accept positional arguments" >&2
                        exit 2
                        ;;
                esac
            done
            update_apply "$backup_first"
            ;;

        *)
            echo "Error: Unknown update subcommand: $subcmd" >&2
            echo "Valid subcommands: check, plan, apply" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# BACKUP COMMAND HANDLER
# ============================================================================

cmd_backup() {
    local subcmd="${1:-}"
    shift || true
    
    case "$subcmd" in
        now)
            local verify=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --verify) verify=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_now "$verify"
            ;;
            
        list)
            local fmt="text"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --format) fmt="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_list "$fmt"
            ;;
            
        verify)
            local file=""
            local level=1
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --level) level="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) 
                        if [[ -z "$file" ]]; then
                            file="$1"
                            shift
                        else
                            break
                        fi
                        ;;
                esac
            done
            if [[ -z "$file" ]]; then
                echo "Error: backup file required" >&2
                exit 2
            fi
            backup_verify "$file" "$level"
            ;;
            
        restore)
            local file=""
            local dry_run=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --dry-run) dry_run=true; shift ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *)
                        if [[ -z "$file" ]]; then
                            file="$1"
                            shift
                        else
                            break
                        fi
                        ;;
                esac
            done
            if [[ -z "$file" ]]; then
                echo "Error: backup file required" >&2
                exit 2
            fi
            backup_restore "$file" "$dry_run"
            ;;
            
        clean)
            local keep_last=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --keep-last) keep_last="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            backup_clean "$keep_last"
            ;;
            
        schedule)
            local schedule_type=""
            local schedule_value=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --daily) schedule_type="daily"; schedule_value="$2"; shift 2 ;;
                    --weekly) schedule_type="weekly"; schedule_value="$2"; shift 2 ;;
                    --) shift; break ;;
                    -*) echo "Unknown option: $1"; exit 2 ;;
                    *) break ;;
                esac
            done
            if [[ -z "$schedule_type" ]]; then
                echo "Error: --daily or --weekly required" >&2
                exit 2
            fi
            backup_schedule "$schedule_type" "$schedule_value"
            ;;
            
        *)
            echo "Error: Unknown backup subcommand: $subcmd" >&2
            echo "Valid subcommands: now, list, verify, restore, clean, schedule" >&2
            exit 2
            ;;
    esac
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    parse_global_options "$@"
    
    # Shift consumed global options - parse_global_options stops at first non-option
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) shift ;;
            -f|--format) shift 2 ;;
            -c|--config) shift 2 ;;
            --) shift; break ;;
            -*) shift ;;  # Unknown option, let command handle it
            *) break ;;
        esac
    done
    
    if [[ $# -eq 0 ]]; then
        echo "Error: No command specified" >&2
        show_help >&2
        exit 2
    fi
    
    local cmd="$1"
    shift
    
    case "$cmd" in
        server)
            cmd_server "$@"
            ;;
        account)
            cmd_account "$@"
            ;;
        update)
            cmd_update "$@"
            ;;
        config)
            cmd_config "$@"
            ;;
        backup)
            cmd_backup "$@"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo "Error: Unknown command: $cmd" >&2
            show_help >&2
            exit 2
            ;;
    esac
}

main "$@"
